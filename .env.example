APP_NAME=SimpCommerce
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000
ADMIN_URL=http://localhost:5173
STOREFRONT_URL=http://localhost:3000

# Comma-separated CORS origins (overrides ADMIN_URL + STOREFRONT_URL when set).
# Use this in production or when running multiple dashboard/storefront instances.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# Allow any localhost port for CORS (default true). Set false in production.
CORS_ALLOW_LOCALHOST=true

# Sanctum stateful domains — domains that can authenticate via session cookies.
# These are the SPA dashboard and storefront domains (with ports).
# In development, localhost URLs are auto-configured; set explicitly for production.
# SANCTUM_STATEFUL_DOMAINS=admin.simpcommerce.com,storefront.simpcommerce.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

NIGHTWATCH_ENABLED=true
NIGHTWATCH_TOKEN="your-nightwatch-token"

LOG_CHANNEL=nightwatch
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_HOST_READ=127.0.0.1
DB_PORT=5432
DB_DATABASE=simp_commerce
DB_USERNAME=postgres
DB_PASSWORD=secret
DB_PERSISTENT=false
DB_EMULATE_PREPARES=false

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Google OAuth Configuration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# Stripe (card payments)
# STRIPE_KEY=pk_test_xxx
# STRIPE_SECRET=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx

# For local Stripe webhook testing, use:
#   stripe listen --forward-to localhost:8000/api/stripe/webhook
# This requires the Stripe CLI: https://stripe.com/docs/stripe-cli

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@simpcommerce.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Mailtrap (development) ────────────────────────────────────
# Uncomment and fill in your Mailtrap credentials to test emails locally.
# MAIL_MAILER=smtp
# MAIL_HOST=sandbox.smtp.mailtrap.io
# MAIL_PORT=2525
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"


