# ─── SimpCommerce — Production Environment ─────────────────────
# Copy this to .env and fill in your production credentials.
#   cp .env.production.example .env

APP_NAME=SimpCommerce
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.simpcommerce.com

# Frontend SPA URLs — used for CORS, password reset links, and OAuth redirects.
ADMIN_URL=https://admin.simpcommerce.com
STOREFRONT_URL=https://storefront.simpcommerce.com

# CORS — in production, allow only your real frontend origins.
# CORS_ALLOWED_ORIGINS=https://admin.simpcommerce.com,https://storefront.simpcommerce.com
CORS_ALLOW_LOCALHOST=false

# Sanctum stateful domains — the exact host (including port if non-standard)
# that your SPA requests originate from. Required for session-based auth.
SANCTUM_STATEFUL_DOMAINS=admin.simpcommerce.com,storefront.simpcommerce.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=nightwatch
LOG_STACK=single
LOG_LEVEL=warning

# Database — use a dedicated user with limited permissions.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_HOST_READ=127.0.0.1
DB_PORT=5432
DB_DATABASE=simp_commerce
DB_USERNAME=simpcommerce
DB_PASSWORD=

# Session — database or redis recommended for production.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.simpcommerce.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Mail — configure your SMTP provider.
MAIL_MAILER=smtp
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="orders@simpcommerce.com"
MAIL_FROM_NAME="${APP_NAME}"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.simpcommerce.com/api/auth/oauth/google/callback

# Redis (optional — comment out if not using)
# REDIS_CLIENT=predis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
